# Dockerfile for PC Agent Sandbox
FROM node:22-alpine

# Install network utilities for diagnostic commands (ping, dns query, processes)
RUN apk add --no-cache iputils bind-tools procps

WORKDIR /app

# Install dependencies first for caching optimization
COPY src/pc-agent/package*.json ./
RUN npm install

# Copy PC Agent source files
COPY src/pc-agent/ ./

# Port 3001 for WebSocket/HTTP Server
EXPOSE 3001

# Start the agent
CMD ["node", "index.js"]
